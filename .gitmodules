[submodule "tpm"]
	path = tmux/plugins/tpm
	url = git@github.com:tmux-plugins/tpm.git
[submodule "fast-syntax-highlighting"]
	path = zsh/plugins/fast-syntax-highlighting
	url = git@github.com:zdharma-zmirror/fast-syntax-highlighting.git
[submodule "zsh-autosuggestions"]
	path = zsh/plugins/zsh-autosuggestions
	url = git@github.com:zsh-users/zsh-autosuggestions.git
[submodule "zsh-completions"]
	path = zsh/plugins/zsh-completions
    url = git@github.com:zsh-users/zsh-completions.git
[submodule "global-nav"]
	path = global-nav
	url = git@github.com:TheSantacloud/global-nav.git
